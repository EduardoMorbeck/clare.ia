# Ordem de fallback dos provedores de IA (o primeiro disponível é o principal).
LLM_PROVIDERS=mistral,gemini,groq

MISTRAL_API_KEY=cole_sua_chave_aqui
MISTRAL_MODEL=mistral-small-latest

GEMINI_API_KEY=cole_sua_chave_aqui
GEMINI_MODEL=gemini-2.5-flash-lite

GROQ_API_KEY=cole_sua_chave_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# Origens permitidas no CORS (separadas por vírgula). Em produção, troque pelo
# domínio do frontend.
ALLOWED_ORIGINS=http://localhost:5173

# Máximo de mensagens do histórico reenviadas ao modelo a cada requisição.
MAX_HISTORY_MESSAGES=20

# Ordem de fallback dos provedores de IA (o primeiro disponível é o principal).
# Provedores com chave configurada que não estiverem listados aqui entram no fim.
LLM_PROVIDERS=gemini,cerebras,groq,mistral

MISTRAL_API_KEY=cole_sua_chave_aqui
MISTRAL_MODEL=mistral-small-latest

GEMINI_API_KEY=cole_sua_chave_aqui
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=cole_sua_chave_aqui
# llama-3.1-8b-instant foi depreciado pela Groq (17/06/2026); use gpt-oss.
GROQ_MODEL=openai/gpt-oss-20b

CEREBRAS_API_KEY=cole_sua_chave_aqui
# Modelos da Cerebras variam conforme o acesso da sua chave (veja /v1/models).
CEREBRAS_MODEL=zai-glm-4.7

# Origens permitidas no CORS (separadas por vírgula). Em produção, troque pelo
# domínio do frontend.
ALLOWED_ORIGINS=http://localhost:5173

# Máximo de mensagens do histórico reenviadas ao modelo a cada requisição.
MAX_HISTORY_MESSAGES=20

# Tamanho máximo (caracteres) de uma única mensagem. Acima disso → HTTP 422.
MAX_MESSAGE_CHARS=4000

# Máximo de mensagens aceitas no corpo da requisição (anti-abuso de payload).
# O histórico ainda é truncado em MAX_HISTORY_MESSAGES antes de ir ao modelo.
MAX_MESSAGES=100

# Teto de tokens de saída que o cliente pode pedir (limita custo por requisição).
MAX_OUTPUT_TOKENS=2048

# Limite de requisições por IP no /api/chat (formato do slowapi, ex.: "30/minute").
CHAT_RATE_LIMIT=30/minute

# Ative (true) SOMENTE se o app rodar atrás de um reverse proxy/CDN de confiança.
# Faz o rate limit usar o IP real do cliente (X-Forwarded-For) em vez do IP do
# proxy. Se ativar sem um proxy à frente, um cliente pode forjar o cabeçalho.
TRUST_PROXY_HEADERS=false

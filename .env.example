# Ordem de fallback dos provedores de IA (o primeiro disponível é o principal).
# Provedores com chave configurada que não estiverem listados aqui entram no fim.
LLM_PROVIDERS=gemini,groq,mistral,cerebras

MISTRAL_API_KEY=cole_sua_chave_aqui
MISTRAL_MODEL=mistral-small-latest

GEMINI_API_KEY=cole_sua_chave_aqui
GEMINI_MODEL=gemini-2.5-flash-lite

GROQ_API_KEY=cole_sua_chave_aqui
GROQ_MODEL=llama-3.1-8b-instant

CEREBRAS_API_KEY=cole_sua_chave_aqui
# Modelos da Cerebras variam conforme o acesso da sua chave (veja /v1/models).
CEREBRAS_MODEL=zai-glm-4.7

# Origens permitidas no CORS (separadas por vírgula). Em produção, troque pelo
# domínio do frontend.
ALLOWED_ORIGINS=http://localhost:5173

# Máximo de mensagens do histórico reenviadas ao modelo a cada requisição.
MAX_HISTORY_MESSAGES=20

# Tamanho máximo (caracteres) de uma única mensagem. Acima disso → HTTP 422.
MAX_MESSAGE_CHARS=4000

# Limite de requisições por IP no /api/chat (formato do slowapi, ex.: "30/minute").
CHAT_RATE_LIMIT=30/minute
